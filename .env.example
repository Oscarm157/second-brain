# Copia a .env.local y rellena. NUNCA comitees .env.local.
# Postgres (Neon u otro). Driver: @neondatabase/serverless.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Secreto para firmar sesiones. Mínimo 16 chars. Genera uno:
#   openssl rand -base64 32
AUTH_SECRET=

# Categorización de movimientos con IA (Claude Haiku). Sin esta key, el import
# usa solo las reglas base; con ella, clasifica el resto automáticamente.
ANTHROPIC_API_KEY=

# Solo para preview por IP sobre HTTP (no HTTPS): baja el flag Secure de la cookie
# de sesión para que el login persista. NO ponerla en producción HTTPS.
# PREVIEW_HTTP=1

# Opcionales segun lo que uses:
BLOB_READ_WRITE_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=

# Recordatorio diario de hábitos (cron de Vercel, ver vercel.json). Vercel manda
# este secreto solo en la llamada real del cron; genera uno con openssl rand -base64 32.
CRON_SECRET=

# Sentry (errores en prod). Sin DSN, Sentry queda inerte (no rompe nada).
NEXT_PUBLIC_SENTRY_DSN=
